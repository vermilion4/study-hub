---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import ProgressBar from '../../components/ProgressBar.astro';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((c) => ({ params: { slug: c.slug }, props: { course: c } }));
}

const { course } = Astro.props;
const all = await getCollection('resources');
const resources = all
  .filter((r) => r.data.course === course.slug)
  .sort((a, b) => a.data.order - b.data.order);

// group by topic, preserving first-seen order
const topics: { topic: string; items: typeof resources }[] = [];
for (const r of resources) {
  let g = topics.find((t) => t.topic === r.data.topic);
  if (!g) { g = { topic: r.data.topic, items: [] }; topics.push(g); }
  g.items.push(r);
}
const resourceIds = resources.map((r) => r.id);
const decks = await getCollection('flashcards');
const deckTopics = new Set(
  decks.filter((d) => d.data.course === course.slug).map((d) => d.data.topic),
);
const hasAnyDeck = deckTopics.size > 0;
---
<Base title={course.data.title}>
  <p><a href="/">← All courses</a></p>
  <h1>{course.data.title}</h1>
  <p style="color:var(--muted)">{course.data.description}</p>
  <div style="margin:16px 0" id="progress-bar-wrap" data-resource-ids={JSON.stringify(resourceIds)}>
    <ProgressBar percent={0} />
  </div>
  <p id="course-progress-label" style="color:var(--muted); font-size:13px"></p>
  {hasAnyDeck && (
    <p style="margin:8px 0 0"><a class="btn" href={`/review?course=${encodeURIComponent(course.slug)}`}>Review this course</a></p>
  )}

  {topics.length === 0 && <p><em>No resources added yet. Drop a file in <code>src/content/resources/{course.slug}/</code>.</em></p>}

  {topics.map((t) => (
    <section style="margin-top:36px">
      <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:14px">
        <h2 style="font-size:18px; margin:0">{t.topic}</h2>
        {deckTopics.has(t.topic) && (
          <a class="review-btn btn" style="font-size:13px"
             data-topic-ids={JSON.stringify(t.items.map((r) => r.id))}
             href={`/review?course=${encodeURIComponent(course.slug)}&topic=${encodeURIComponent(t.topic)}`}>Review</a>
        )}
      </div>
      {t.items.map((r) => (
        <ResourceCard id={r.id} title={r.data.title} type={r.data.type}
          url={r.data.url} estMinutes={r.data.estMinutes} difficulty={r.data.difficulty} />
      ))}
    </section>
  ))}

  <script>
    import * as p from '../../lib/progress';

    const wrap = document.getElementById('progress-bar-wrap');
    const resourceIds: string[] = wrap ? JSON.parse(wrap.dataset.resourceIds ?? '[]') : [];
    const progress = document.querySelector('.progress');
    const bar = progress?.querySelector('span') as HTMLElement | null;
    const label = document.getElementById('course-progress-label');

    const refresh = () => {
      const pct = p.courseProgress(resourceIds);
      if (bar) bar.style.width = pct + '%';
      if (progress) progress.setAttribute('aria-label', pct + '% complete');
      if (label) label.textContent = pct + '% complete';
      document.querySelectorAll('.review-btn').forEach((el) => {
        const ids = JSON.parse(el.getAttribute('data-topic-ids') || '[]');
        const done = ids.length > 0 && p.courseProgress(ids) === 100;
        (el as HTMLElement).style.background = done ? 'var(--accent)' : '';
        (el as HTMLElement).style.color = done ? '#fff' : '';
        (el as HTMLElement).style.borderColor = done ? 'var(--accent)' : '';
      });
    };

    document.querySelectorAll('.resource').forEach((el) => {
      const id = el.getAttribute('data-resource-id');
      const box = el.querySelector('.done-box') as HTMLInputElement | null;
      if (id && box) {
        box.checked = p.isDone(id);
        box.addEventListener('change', () => { p.toggle(id); refresh(); });
      }
    });

    refresh();
  </script>
</Base>
